{
  "id": "xiaomimimo",
  "displayName": "platform.xiaomimimo.com",
  "match": {
    "hostPatterns": ["platform.xiaomimimo.com", "xiaomimimo.com"],
    "defaultDisplayName": "platform.xiaomimimo.com",
    "defaultTokenChannelEnabled": false,
    "defaultBalanceChannelEnabled": true
  },
  "setup": {
    "recommendedBaseURL": "https://platform.xiaomimimo.com",
    "requiredInputs": ["balanceAuth"],
    "balanceAuthHint": {
      "zhHans": "粘贴浏览器请求里的完整 Cookie，通常至少包含 `api-platform_serviceToken`、`userId`、`api-platform_slh`、`api-platform_ph`。模板会自动先访问 `/api/v1/userProfile`，再探测 `/api/v1/balance` 获取余额。",
      "en": "Paste the full Cookie value from your browser request. It usually includes `api-platform_serviceToken`, `userId`, `api-platform_slh`, and `api-platform_ph`. The template first checks `/api/v1/userProfile`, then probes `/api/v1/balance` for the actual balance."
    }
  },
  "authStrategies": [
    { "kind": "savedCookieHeader" },
    { "kind": "browserCookieHeader" }
  ],
  "balanceRequest": {
    "method": "GET",
    "path": "/api/v1/userProfile",
    "authHeader": "Cookie",
    "authScheme": "",
    "headers": {
      "X-Timezone": "Asia/Shanghai"
    }
  },
  "extract": {
    "remaining": "coalesce(data.balance,data.user.balance,data.wallet.balance,data.walletBalance,data.accountBalance,data.availableBalance,balance,walletBalance,accountBalance,availableBalance)",
    "used": "coalesce(data.monthlyUsage,data.monthlySpend,data.used,data.consume,monthlyUsage,monthlySpend,used,consume)",
    "unit": "\"CNY\"",
    "accountLabel": "coalesce(data.nickName,data.nickname,data.userName,data.user.name,nickName,nickname,userName,name)"
  }
}
